# ── 데이터베이스
DATABASE_URL=postgresql+asyncpg://npl:npl@db:5432/npl_db

# ── Redis
REDIS_URL=redis://redis:6379

# ── JWT
JWT_SECRET_KEY=CHANGE_ME_to_random_256bit_string_in_production
JWT_ACCESS_EXPIRE_HOURS=2
JWT_REFRESH_EXPIRE_DAYS=7

# ── 파일 스토리지 (환경별로 하나만 활성화)
FILE_SERVER_MODE=mock
LOCAL_UPLOAD_DIR=/tmp/uploads
# AZURE_STORAGE_CONNECTION=DefaultEndpoints...
# AZURE_STORAGE_CONTAINER=npl-files
# FILE_SERVER_API_URL=https://...
# FILE_SERVER_API_KEY=...

# ── 파일 암호화 (AES-256, 정확히 32자)
FILE_ENCRYPTION_KEY=CHANGE_ME_exactly_32_characters!!

# ── CORS
ALLOWED_ORIGINS=http://localhost:3000

# ── Azure AD SSO (정식 전환 시 활성화)
# AZURE_AD_TENANT_ID=
# AZURE_AD_CLIENT_ID=
# AZURE_AD_CLIENT_SECRET=
